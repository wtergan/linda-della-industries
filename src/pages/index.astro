---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import HorizonEngine from '../components/HorizonEngine.astro';

const title = 'Linda Della Industries | Practical AI systems for Baltimore businesses';
const description = 'A Baltimore-based independent studio offering one scoped, human-reviewed AI workflow pilot for $1,000, delivered in seven calendar days for accepted projects.';
const base = import.meta.env.BASE_URL;
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Linda Della Industries',
  founder: { '@type': 'Person', name: 'William Doran IV' },
  areaServed: ['Baltimore', 'Maryland', 'Washington, DC', 'Northern Virginia'],
  email: 'willdoraniv@gmail.com',
  description,
  url: Astro.site ? new URL(base, Astro.site).href : Astro.url.href,
};
---

<BaseLayout title={title} description={description}>
  <SiteHeader />
  <main id="main-content" tabindex="-1">
    <section class="hero section-shell">
      <div class="shell hero-grid">
        <div class="hero-copy reveal">
          <p class="eyebrow"><span>AI systems</span> Built in Baltimore</p>
          <h1>Turn one recurring workflow into a <em>working pilot</em>—in seven days.</h1>
          <p class="hero-lede">For accepted projects, Linda Della Industries maps, builds, tests, and hands off one human-reviewed AI workflow pilot for an owner-led business across Baltimore or the DMV. No vague strategy deck.</p>
          <div class="hero-actions">
            <a class="button button-primary" href="#contact">Request a founding sprint</a>
            <a class="text-link" href="#sprint">See exactly what ships <span aria-hidden="true">↓</span></a>
          </div>
          <dl class="offer-rail" aria-label="Founding sprint summary">
            <div><dt>Founding rate</dt><dd>$1,000 flat</dd></div>
            <div><dt>Delivery</dt><dd>7 days after kickoff</dd></div>
            <div><dt>Scope</dt><dd>1 agreed pilot</dd></div>
          </dl>
        </div>
        <div class="hero-art reveal reveal-delay"><HorizonEngine /></div>
      </div>
    </section>

    <section class="proof-bar" aria-label="Working principles">
      <div class="shell proof-track">
        <span>Start with your current tools</span><i aria-hidden="true"></i>
        <span>Human approval by default</span><i aria-hidden="true"></i>
        <span>No long-term contract</span><i aria-hidden="true"></i>
        <span>Built by a Baltimore-based studio</span>
      </div>
    </section>

    <section class="section-shell problem-section" id="problems">
      <div class="shell split-intro">
        <div>
          <p class="section-index">01 / Find the drag</p>
          <h2>Start where work keeps slipping through.</h2>
        </div>
        <p>Your first AI system should not be a moonshot. It should remove a visible bottleneck without creating a new one.</p>
      </div>
      <div class="shell use-case-ledger" aria-label="Examples of good first workflows">
        <article><span class="ledger-number">A</span><div><h3>Leads wait too long</h3><p>Turn website or inbox inquiries into structured details, a response draft, and an owner approval queue.</p></div><small>Response workflow</small></article>
        <article><span class="ledger-number">B</span><div><h3>The inbox runs the day</h3><p>Classify recurring requests, extract the fields that matter, and route exceptions to the right person.</p></div><small>Intake workflow</small></article>
        <article><span class="ledger-number">C</span><div><h3>Meetings lose momentum</h3><p>Convert notes into decisions, assigned actions, and follow-up drafts before the next task takes over.</p></div><small>Follow-through workflow</small></article>
        <article><span class="ledger-number">D</span><div><h3>Documents get retyped</h3><p>Extract repeatable fields into a reviewable table, while keeping uncertain results in a human exception queue.</p></div><small>Document workflow</small></article>
      </div>
    </section>

    <section class="section-shell sprint-section" id="sprint">
      <div class="shell sprint-frame">
        <div class="sprint-heading">
          <p class="section-index">02 / The founding offer</p>
          <h2>The 7-Day AI Workflow Sprint</h2>
          <p>A fixed first engagement for teams that know where the friction is and want a working pilot—not another presentation.</p>
        </div>
        <ol class="timeline">
          <li><div class="day">Day 1</div><div><h3>Map</h3><p>One focused working session to trace the people, tools, data, exceptions, and success measure.</p></div></li>
          <li><div class="day">Days 2–5</div><div><h3>Build</h3><p>I assemble one narrow workflow around compatible tools you already use, with agreed ownership and approval steps.</p></div></li>
          <li><div class="day">Day 6</div><div><h3>Test</h3><p>We run realistic examples, edge cases, and failure paths. Uncertain output goes to a person—not straight to a customer.</p></div></li>
          <li><div class="day">Day 7</div><div><h3>Hand off</h3><p>Your team receives the agreed pilot, a walkthrough, operating notes, and 14 calendar days for correction of defects within the written scope.</p></div></li>
        </ol>
        <div class="sprint-price">
          <div><span>Founding-client rate</span><strong>$1,000</strong><small>flat project fee</small></div>
          <ul>
            <li>One scoped workflow pilot ready for client testing</li>
            <li>Test scenarios and data-flow notes</li>
            <li>Live handoff or recorded walkthrough</li>
            <li>14 days of in-scope defect corrections</li>
          </ul>
          <p>Third-party costs are approved in writing before they are incurred and are either paid directly by you or reimbursed at cost. Any recommended tool change requires your approval.</p>
          <p>This launch offer is for accepted, narrowly scoped first projects. Fit and availability are confirmed before an agreement is signed, and the seven-day period begins after kickoff and required access.</p>
          <a class="button button-gold" href="#contact">Apply for the founding rate</a>
        </div>
      </div>
    </section>

    <section class="section-shell fit-section" id="fit">
      <div class="shell">
        <div class="split-intro">
          <div><p class="section-index">03 / Fit before hype</p><h2>A small, useful system is the test.</h2></div>
          <p>I will say when AI is the wrong tool. The sprint works best when the workflow already happens often enough to observe.</p>
        </div>
        <div class="fit-grid">
          <div class="fit-column fit-yes"><h3>Good first fit</h3><ul><li>Owner-led team of roughly 3–50 people</li><li>A repeated process with a clear start and finish</li><li>One person owns the decision and can test quickly</li><li>The team wants human review, documentation, and control</li><li>A useful pilot matters more than an “AI transformation” slogan</li></ul></div>
          <div class="fit-column fit-no"><h3>Not a launch fit</h3><ul><li>Medical, legal, credit, hiring, or other high-stakes decisions</li><li>A promise to replace an entire role in a week</li><li>Unsupervised mass outreach or autonomous calling</li><li>Sensitive data without the right security and legal review</li><li>A guaranteed revenue number before a baseline exists</li></ul></div>
        </div>
      </div>
    </section>

    <section class="section-shell founder-section" id="founder">
      <div class="shell founder-grid">
        <div class="founder-portrait" role="img" aria-label="Geometric monogram portrait for founder William Doran IV">
          <div class="portrait-field"><span>WD</span><i></i><b>Baltimore<br />Maryland</b></div>
        </div>
        <div class="founder-copy">
          <p class="section-index">04 / Your builder</p>
          <h2>Deep technical roots. Plain business language.</h2>
          <p class="founder-lede">I’m William Doran IV, a Baltimore software and AI engineer. I began learning and building with neural networks in the mid-2010s—before generative AI became a mainstream business topic.</p>
          <p>My work now centers on agentic systems, software automation, testing, and the orchestration needed to make AI tools behave like dependable parts of a larger process. For a client, that depth only matters if it becomes a system your team can understand and use.</p>
          <div class="founder-links"><a href="https://github.com/wtergan" rel="me">Review my GitHub</a><a href="mailto:willdoraniv@gmail.com">Email me directly</a></div>
        </div>
        <aside class="origin-note">
          <p class="origin-kicker">Why “Linda Della”</p>
          <p>The company carries the names of my grandmothers. The long vision is to build technology that expands human capability across generations. The near-term discipline is simpler: make one real business better, then earn the right to build the next thing.</p>
          <strong>Built for the long arc.<br />Useful this week.</strong>
        </aside>
      </div>
    </section>

    <section class="section-shell evidence-section">
      <div class="shell evidence-grid">
        <div><p class="section-index">05 / The implementation gap</p><h2>Businesses do not need more AI noise.</h2></div>
        <div class="evidence-copy">
          <p>In NFIB’s 2025 technology survey, 42% of small-business owners said they were not at all familiar with AI tools designed for business operations or their industry. Maryland SBDC offers no-cost one-on-one AI guidance, tool evaluation, training, and workflow help.</p>
          <p>The Linda Della sprint is a separate paid, fixed-scope implementation offer: one agreed workflow mapped, built, tested, and handed over in seven calendar days.</p>
          <div class="source-links"><a href="https://www.nfib.com/wp-content/uploads/2025/06/2025-NFIB-Technology-Survey-1.pdf">NFIB 2025 survey <span aria-hidden="true">↗</span></a><a href="https://www.marylandsbdc.org/consulting/technology-and-ai-advisory-services">Maryland SBDC AI services <span aria-hidden="true">↗</span></a></div>
        </div>
      </div>
    </section>

    <section class="section-shell faq-section" id="faq">
      <div class="shell faq-grid">
        <div><p class="section-index">06 / Straight answers</p><h2>Before we talk.</h2></div>
        <div class="faq-list">
          <details><summary>What tools can you work with?</summary><p>The right stack depends on your current process. Common launch surfaces include email, forms, spreadsheets, calendars, CRMs, document stores, and APIs. The first call determines what is feasible without forcing a migration.</p></details>
          <details><summary>Do I need to know which AI tool I want?</summary><p>No. Bring the repeated work and the failure points. Tool selection comes after the workflow and risk are clear.</p></details>
          <details><summary>Will this replace an employee?</summary><p>That is not the sprint’s promise. The aim is to remove low-leverage handling, shorten response time, and give people a better queue. Human approval stays in consequential or customer-facing steps by default.</p></details>
          <details><summary>Is this compliance or legal advice?</summary><p>No. I can document data movement, minimize collection, and build technical safeguards, but regulated workflows require the right legal, privacy, security, or industry specialist.</p></details>
          <details><summary>What happens after seven days?</summary><p>You receive the workflow configuration and documentation identified in the written agreement. Third-party platforms and licensed components remain subject to their own terms. The sprint includes 14 calendar days for defects within the agreed scope; ongoing support is separate.</p></details>
        </div>
      </div>
    </section>

    <section class="contact-section" id="contact">
      <div class="shell contact-grid">
        <div class="contact-copy">
          <p class="section-index">07 / Start small</p>
          <h2>Show me the workflow that keeps stealing time.</h2>
          <p>If it is a credible seven-day fit, I will tell you what I would build. If it is not, I will say that too.</p>
          <div class="contact-direct"><span>Prefer email?</span><a href="mailto:willdoraniv@gmail.com?subject=Linda%20Della%20Workflow%20Sprint">willdoraniv@gmail.com</a><small>Baltimore • Maryland • DC • Northern Virginia</small></div>
        </div>
        <form class="contact-form" action="https://formsubmit.co/willdoraniv@gmail.com" method="POST" data-ajax-action="https://formsubmit.co/ajax/willdoraniv@gmail.com" data-contact-form>
          <input type="hidden" name="_subject" value="Linda Della — new workflow sprint inquiry" />
          <input type="hidden" name="_template" value="table" />
          <input class="hp-field" type="text" name="_honey" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <div class="field-row">
            <label>Full name<input required autocomplete="name" maxlength="100" name="name" type="text" /></label>
            <label>Email<input required autocomplete="email" autocapitalize="none" maxlength="254" spellcheck="false" name="email" type="email" /></label>
          </div>
          <div class="field-row">
            <label>Business or organization <span>(optional)</span><input autocomplete="organization" maxlength="150" name="company" type="text" /></label>
            <label>Website <span>(optional)</span><input autocomplete="url" autocapitalize="none" maxlength="300" spellcheck="false" inputmode="url" name="website" type="url" placeholder="https://example.com" /></label>
          </div>
          <label>What keeps repeating?<textarea required maxlength="3000" minlength="20" name="workflow" rows="5" placeholder="Example: Every web inquiry has to be copied into a spreadsheet, researched, and answered by hand…"></textarea></label>
          <label class="consent"><input required name="consent" type="checkbox" value="I agree to be contacted about this inquiry" /><span>I agree to be contacted about this inquiry. Please do not include sensitive or regulated information. See the <a href={`${base}privacy/`}>privacy notice</a>.</span></label>
          <button class="button button-primary submit-button" type="submit"><span>Send the workflow</span><i aria-hidden="true">→</i></button>
          <p class="form-status" role="status" aria-live="polite" data-form-status>I aim to reply within one business day.</p>
          <noscript><p>JavaScript is off. You can still submit this form; FormSubmit will show its confirmation page.</p></noscript>
        </form>
      </div>
    </section>
  </main>
  <SiteFooter />
  <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  <script>
    const form = document.querySelector('[data-contact-form]');
    const status = document.querySelector('[data-form-status]');

    if (form instanceof HTMLFormElement && status instanceof HTMLElement) {
      let isDirty = false;
      form.addEventListener('input', () => { isDirty = true; });
      window.addEventListener('beforeunload', (event) => {
        if (!isDirty) return;
        event.preventDefault();
      });
      form.addEventListener('submit', async (event) => {
        event.preventDefault();
        const button = form.querySelector('button[type="submit"]');
        const data = new FormData(form);
        if (data.get('_honey')) return;
        const buttonLabel = button?.querySelector('span');
        if (button instanceof HTMLButtonElement) button.disabled = true;
        if (buttonLabel instanceof HTMLElement) buttonLabel.textContent = 'Sending…';
        form.setAttribute('aria-busy', 'true');
        status.textContent = 'Sending your workflow…';
        try {
          const response = await fetch(form.dataset.ajaxAction || form.action, {
            method: 'POST',
            body: data,
            headers: { Accept: 'application/json' },
          });
          if (!response.ok) throw new Error('Submission failed');
          form.reset();
          isDirty = false;
          status.textContent = 'Submitted. I’ll review the workflow and reply by email.';
          status.classList.add('is-success');
        } catch {
          status.textContent = 'The form could not send. Email ';
          const emailLink = document.createElement('a');
          emailLink.href = 'mailto:willdoraniv@gmail.com?subject=Linda%20Della%20Workflow%20Sprint';
          emailLink.textContent = 'willdoraniv@gmail.com';
          status.append(emailLink, ' instead.');
          status.classList.add('is-error');
        } finally {
          if (button instanceof HTMLButtonElement) button.disabled = false;
          if (buttonLabel instanceof HTMLElement) buttonLabel.textContent = 'Send the workflow';
          form.removeAttribute('aria-busy');
        }
      });
    }
  </script>
</BaseLayout>
