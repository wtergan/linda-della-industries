---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  noindex?: boolean;
}

const { title, description, image = 'og-card.svg', noindex = false } = Astro.props;
const base = import.meta.env.BASE_URL;
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site) : Astro.url;
const imageUrl = Astro.site ? new URL(`${base}${image}`, Astro.site) : new URL(`${base}${image}`, Astro.url);
const productionCsp = "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:; connect-src 'self' https://formsubmit.co; form-action https://formsubmit.co; base-uri 'self'; object-src 'none'";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#f1e8d7" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    {import.meta.env.PROD && <meta http-equiv="Content-Security-Policy" content={productionCsp} />}
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Linda Della Industries" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={imageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <slot />
  </body>
</html>
